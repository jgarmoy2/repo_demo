# ============================================================================
# profiles.yml.example — PLANTILLA de profile para dbt Core
# ============================================================================
# ⚠️ Este archivo es un EJEMPLO. Nunca commitees tu profiles.yml real con
# credenciales. Cópialo a ~/.dbt/profiles.yml y rellena tus valores.
#
# En dbt Cloud no necesitáis este archivo: la conexión se configura desde
# la UI (Account Settings → Projects → Connection).
# ============================================================================

default:                          # Debe coincidir con `profile:` en dbt_project.yml
  target: dev                     # Target activo por defecto

  outputs:

    # ------------------------------------------------------------------------
    # Target DEV (entorno personal del desarrollador)
    # ------------------------------------------------------------------------
    dev:
      type: snowflake
      account: civicapartner.west-europe.azure
      user: ALUMNOX                         # Sustituir por vuestro usuario
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"

      role: CURSO_DATA_ENGINEERING
      warehouse: WH_CURSO_DATA_ENGINEERING

      database: ALUMNOX_DEV_SILVER_DB       # BD por defecto (la sobreescriben los models)
      schema: dbt_alumnox                   # Schema personal de desarrollo

      threads: 4
      client_session_keep_alive: false

    # ------------------------------------------------------------------------
    # Target PRO (solo se ejecuta desde dbt Cloud / CI)
    # ------------------------------------------------------------------------
    pro:
      type: snowflake
      account: civicapartner.west-europe.azure
      user: ALUMNOX
      password: "{{ env_var('SNOWFLAKE_PASSWORD') }}"

      role: CURSO_DATA_ENGINEERING
      warehouse: WH_CURSO_DATA_ENGINEERING

      database: ALUMNOX_PRO_SILVER_DB
      schema: dbt                           # En PRO el schema es "dbt" (sin prefijo de usuario)

      threads: 8
      client_session_keep_alive: false
